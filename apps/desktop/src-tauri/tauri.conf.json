{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OblivionisAgent",
  "version": "0.9.6",
  "identifier": "com.oblivionis.agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OblivionisAgent",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "backgroundColor": "#101216",
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "title": "",
        "url": "splash.html",
        "width": 300,
        "height": 360,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "center": true,
        "shadow": true,
        "backgroundColor": "#f1eee6",
        "visible": false
      },
      {
        "label": "mascot",
        "title": "",
        "width": 200,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focus": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "mdviewer",
        "title": "文档查看器 · OblivionisAgent",
        "width": 1080,
        "height": 800,
        "minWidth": 640,
        "minHeight": 460,
        "decorations": true,
        "center": true,
        "visible": false
      },
      {
        "label": "canvas",
        "title": "节点编排 · OblivionisAgent",
        "width": 1280,
        "height": 840,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": true,
        "backgroundColor": "#101216",
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/oblivionis-bridge"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/RudAns/OblivionisAgent/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2QzQwOEM0M0MwQjZBNQpSV1NsdHNCRGpFQnNEdGhrOEZRSDRlUzdiSXFnakZRZnpURy91TzNibzdZRllLUkxpQmkvTHVqSgo=",
      "windows": { "installMode": "passive" }
    }
  }
}
